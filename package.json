  },
  "homepage": "https://github.com/synatic/parameter-parser#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@synatic/json-magic": "^1.1.0",
    "check-types": "11.2.3",
    "clone-deep": "4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "mongodb": "^7.1.1",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1"
  }
